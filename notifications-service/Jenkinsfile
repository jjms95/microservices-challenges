pipeline {
    agent any
    environment {
        SCANNER_HOME = tool 'SonarScanner'
    }
    stages {
        stage('Build') {
            steps {
                dir('notifications-service') {
                    echo "Instalando dependencias de Python..."
                    sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt
                    '''
                }
            }
        }
        stage('Test & Coverage') {
            steps {
                dir('notifications-service') {
                    echo "Ejecutando pruebas y generando cobertura..."
                    sh '''
                    . venv/bin/activate
                    pytest --cov=app --cov-report=xml
                    '''
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir('notifications-service') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        withSonarQubeEnv('SonarQube') {
                            sh "${SCANNER_HOME}/bin/sonar-scanner -Dsonar.token=\$SONAR_TOKEN"
                        }
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        stage('Package') {
            steps {
                dir('notifications-service') {
                    script {
                        def imageName = "localhost:5000/notifications-service"
                        def imageTag = "${env.BUILD_NUMBER}"
                        sh "docker build -t ${imageName}:${imageTag} -t ${imageName}:latest ."
                        sh "docker push ${imageName}:${imageTag}"
                        sh "docker push ${imageName}:latest"
                    }
                }
            }
        }
        stage('E2E Tests') {
            steps {
                echo "Levantando el sistema y corriendo pruebas E2E..."
                sh 'docker compose up -d'
                sh 'sleep 30'
                dir('e2e-tests') {
                    sh '''
                    npm install
                    npm test
                    '''
                }
            }
            post {
                always {
                    echo "Limpiando entorno E2E..."
                    sh 'docker compose down'
                }
            }
        }
    }
    post {
        success {
            echo "✅ Pipeline completado con éxito"
        }
        failure {
            echo "❌ Pipeline fallido"
        }
    }
}
