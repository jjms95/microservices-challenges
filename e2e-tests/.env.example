# Variables de entorno para la suite BDD
# Copiar a .env y ajustar valores si el sistema corre en otro host/puerto

# URLs base de los servicios
EMPLOYEES_URL=http://localhost:8080
DEPARTMENTS_URL=http://localhost:8081
AUTH_URL=http://localhost:8085
NOTIFICATIONS_URL=http://localhost:8084
PROFILES_URL=http://localhost:8083

# Credenciales de usuarios de prueba (del seed del auth-service)
ADMIN_EMAIL=admin@empresa.com
ADMIN_PASSWORD=Admin123!
USER_EMAIL=usuario@empresa.com
USER_PASSWORD=User123!

# Usuario inactivo (para pruebas de offboarding)
INACTIVE_EMAIL=exempleado@empresa.com

# Parámetros de polling para eventos asincrónicos
POLLING_MAX_ATTEMPTS=15
POLLING_INTERVAL_MS=2000
